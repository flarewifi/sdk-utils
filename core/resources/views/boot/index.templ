package boot

import  sdkapi "sdk/api"

type BootPageData struct {
	API sdkapi.IPluginApi
	SseURL string
	JsSrc string
	CssSrc string
}

templ BootPage(data *BootPageData) {
	<!DOCTYPE html>
	<html lang="en" data-bs-theme="auto">
		<head>
			<title>{ data.API.Translate("label", "boot_progress") }</title>
			<meta name="viewport" content="width=device-width, initial-scale=1"/>
			<link rel="stylesheet" href={ data.CssSrc } />
		</head>
		<body>
			<script src={ data.JsSrc }></script>
			<div> <h2> { data.API.Translate("label", "boot_progress_status") }: </h2> </div>
			<hr/>
			<div id="status-text" hx-ext="sse" sse-connect={ data.SseURL }></div>
		</body>
	</html>
}
