//go:build !mono

package pluginsview

import (
	"fmt"
	"encoding/json"
	"html/template"

	sdkutils "github.com/flarehotspot/sdk-utils"
	sdkapi "sdk/api"
)

type PluginData struct {
	Info               sdkutils.PluginInfo
	Src                sdkutils.PluginSrcDef
	HasPendingUpdate   bool
	HasUpdates         bool
	ToBeRemoved        bool
	StorePluginVersion string
}

type IndexPageData struct {
	Plugins []PluginData
}

templ IndexPage(api sdkapi.IPluginApi, data IndexPageData, formRoutes FormRoutes) {
	{{
		b, _ := json.Marshal(formRoutes)
		jsonData := template.JS(b)
	}}

	<h1>{ api.Translate("label", "Plugins") }</h1>
	<hr/>
	<div class="pb-3" x-data={ fmt.Sprintf("pluginInstaller(%s)", jsonData) }>
		<a class="btn btn-primary" href={ templ.SafeURL(api.Http().Helpers().UrlForRoute("admin:plugins:install")) }>
			{ api.Translate("label", "Install Plugin") }
		</a>
		<div class="pt-3">
			@ProgressBar()
		</div>
	</div>
	<table class="table table-bordered">
		<thead>
			<tr>
				<th>{ api.Translate("label", "Name") }</th>
				<th>{ api.Translate("label", "Status") }</th>
				<th>{ api.Translate("label", "More") }</th>
				<th>{ api.Translate("label", "Actions") }</th>
			</tr>
		</thead>
		<tbody>
			for _, p := range data.Plugins {
			<tr>
				<td>{ p.Info.Name }</td>
				<td>
					if p.ToBeRemoved {
						<span style="color: red;">{ api.Translate("label", "To Be Removed") }</span>
					}
					if p.HasPendingUpdate {
						<span style="color: green;">{ api.Translate("label", "To Be Updated") }</span>
					}
					if !p.ToBeRemoved && !p.HasPendingUpdate {
						<span>{ api.Translate("label", "Installed") }</span>
					}
				</td>
				<td>
					{ fmt.Sprintf("%+v", p.Info) }
				</td>
				<td >
					if !p.ToBeRemoved {
						<span hx-boost="true">
							<a class="btn btn-sm btn-danger" hx-confirm={ api.Translate("label", "Are you sure you want to uninstall this plugin") + "?" } hx-post={
							api.Http().Helpers().UrlForRoute("admin:plugins:uninstall", "pkg" , p.Info.Package) }>
								{ api.Translate("label", "Uninstall") }
							</a>
						</span>
					}

					if p.Src.GitURL != "" {
					<a class="btn btn-sm btn-primary" href={
						templ.SafeURL(api.Http().Helpers().UrlForRoute("admin:plugins:check-updates", "pkg" ,
						p.Info.Package)) }>
							{ api.Translate("label", "Check For Updates") }
					</a>
					}
				</td>
			</tr>
			}
		</tbody>
	</table>
	<div class="alert alert-info">
		{ api.Translate("label", "Plugin Will Be Removed on the Next Restart") }
	</div>
	<div class="alert alert-info">
		{ api.Translate("label", "Plugin Will Be Updated on the Next Restart") }
	</div>
}
