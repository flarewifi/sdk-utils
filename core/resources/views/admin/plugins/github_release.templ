//go:build !mono

package pluginsview

import (
	"time"
	"log"

	sdkapi "sdk/api"
)

type Release struct {
	TagName     string `json:"tag_name"`
	Name        string `json:"name"`
	Body        string `json:"body"`
	PublishedAt string `json:"published_at"`
	TarballURL  string `json:"tarball_url"`
}

templ ReleasesPage(api sdkapi.IPluginApi, data []Release, pluginPkg string) {
	<h1>{ api.Translate("label", "Github Releases") }</h1>
	if len(data) == 0 {
		<h2>{ api.Translate("label", "No available releases") }</h2>
	}
	<div>
		<table class="table table-bordered">
			<thead>
				<td>{ api.Translate("label", "Tag Name") }</td>
				<td>{ api.Translate("label", "Name") }</td>
				<td>{ api.Translate("label", "Description") }</td>
				<td>{ api.Translate("label", "Published Date") }</td>
				<td>{ api.Translate("label", "Download Link") }</td>
			</thead>
			<tbody>
				for _, release := range data {
					{{ publishedDate, err := time.Parse(time.RFC3339, release.PublishedAt) }}
					if err != nil {
						{{ log.Println("err: error") }}
					}

					<tr>
						<td>{ release.TagName }</td>
						<td>{ release.Name }</td>
						<td>{ release.Body }</td>
						<td>{ publishedDate.Format("January 02, 2006") }</td>
						<td>
							{{ pairs := []string{"pkg", pluginPkg, "tag" , release.TagName }}}
							{{ url := api.Http().Helpers().UrlForRoute("admin:plugins:get-update", pairs...) }}
							<a href={ templ.SafeURL(url) }>
								Click Here
							</a>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
}
