{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "templ": {
      "command": ["templ", "lsp"],
      "extensions": ["templ"]
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "ssh": {
      "type": "local",
      "command": ["npx", "@idletoaster/ssh-mcp-server@latest"],
      "enabled": true
    }
  }
}
