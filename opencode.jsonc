{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "templ": {
        "command": ["templ", "lsp"],
        "extensions": ["templ"]
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "sqlite": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-sqlite",
        "./data/db/database.sqlite"
      ],
      "enabled": true
    }
  }
}
